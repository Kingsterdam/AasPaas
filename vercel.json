{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/geocode", "dest": "/api/geocode.js" },
    { "src": "/api/suggest", "dest": "/api/suggest.js" },
    { "src": "/api/places", "dest": "/api/places.js" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}